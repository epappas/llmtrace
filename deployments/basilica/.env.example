# ============================================================================
# LLMTrace Proxy - Basilica Deployment Configuration
# ============================================================================
# Copy to .env and fill in your values before deploying.
# ============================================================================

# --- Basilica Platform ---
BASILICA_API_TOKEN=your-basilica-api-token-here

# --- Docker Image ---
LLMTRACE_IMAGE=ghcr.io/epappas/llmtrace-proxy:latest

# --- Deployment Name ---
DEPLOYMENT_NAME=llmtrace-proxy

# --- Upstream LLM Endpoint ---
LLMTRACE_UPSTREAM_URL=https://6a1d9980-96d6-4f21-b7a6-06b3ec043b2d.deployments.basilica.ai

# --- Storage ---
LLMTRACE_STORAGE_PROFILE=memory

# --- ML Security Analysis ---
LLMTRACE_ML_ENABLED=1
LLMTRACE_ML_PRELOAD=1
LLMTRACE_ML_CACHE_DIR=/home/llmtrace/.cache/llmtrace/models

# --- Logging ---
LLMTRACE_LOG_LEVEL=info
LLMTRACE_LOG_FORMAT=json
RUST_LOG=info

# --- Resource Allocation ---
DEPLOY_CPU=2
DEPLOY_MEMORY=4Gi
DEPLOY_REPLICAS=1

# ============================================================================
# LLMTrace Dashboard
# ============================================================================

# --- Docker Image ---
DASHBOARD_IMAGE=ghcr.io/epappas/llmtrace-dashboard:latest

# --- Deployment Name ---
DASHBOARD_DEPLOYMENT_NAME=llmtrace-dashboard

# --- Proxy Connection ---
# URL of the running LLMTrace proxy (auto-read from .deployment_id if unset)
LLMTRACE_PROXY_URL=

# --- Auth (optional) ---
LLMTRACE_AUTH_ADMIN_KEY=

# --- Resource Allocation ---
DASHBOARD_CPU=1
DASHBOARD_MEMORY=1Gi
DASHBOARD_REPLICAS=1
